@page "/Admin/Configuration"
@inject AuthService authService
@inherits SearchPageBase<Configuration, ConfigurationService, ConfigurationFilter>

<PageTitle>Voreinstellungen</PageTitle>


<FluentBreadcrumb>
    <FluentBreadcrumbItem Href="/">Start</FluentBreadcrumbItem>
    <FluentBreadcrumbItem>Administration</FluentBreadcrumbItem>
    <FluentBreadcrumbItem>Voreinstellungen</FluentBreadcrumbItem>
</FluentBreadcrumb>




<FluentGrid Width="100%">
    <FluentGridItem xs="12" sm="9">
        <FluentStack Orientation="Orientation.Vertical">

            @if (_isLoading)
            {
                <FluentProgressRing />
            }
            else
            {
                @foreach (var item in Data)
                {
                    <div class="list">
                        <div class="list-details">
                            <div class="list-item" hidden-when="xs sm">
                                <label>Id</label>
                                <span>@item.ConfigurationId</span>
                            </div>

                            <div class="list-item">
                                <label>Name</label>
                                <span>@item.GetName()</span>
                            </div>

                            <div class="list-item">
                                <label>Letzte Änderung</label>
                                <span>@item.LastModified?.ToShortDateString()</span>
                            </div>

                            <div class="list-item">
                                <label>Letzter Bearbeiter</label>
                                <span>@item.BearbeiterName</span>
                            </div>
                        </div>
                        <div class="list-buttons">
                            <FluentAnchor Href="@($"/Admin/Configuration/Edit?configurationId={item.GetIdentifier()}")">
                                Bearbeiten
                            </FluentAnchor>
                        </div>
                    </div>
                }

                @if(!_isLoading && Data.Count == 0)
                {
                    <div class="list justify-content-center">
                        Keine Datensätze
                    </div>
                }
            }


            @if (TotalPages > 1)
            {
                <Pagination CurrentPageNumber="Page"
                            TotalItems="TotalItems"
                            ItemsPerPage="Filter.Limit"
                            NavUrl="/Admin/Configuration?page=" />
            }
        </FluentStack>
    </FluentGridItem>
    <FluentGridItem xs="12" sm="3">
        <FluentCard Height="auto">
            <h4>Filter</h4>

            <EditForm Model="Filter" OnValidSubmit="async () => await LoadAsync(true)">
                <FluentStack Orientation="Orientation.Vertical">
                    <FluentTextField @bind-Value="Filter.SearchPhrase" Immediate="true" Label="Suchbegriff" Placeholder="Name" />
                    
                    <FluentButton Type="ButtonType.Submit" IconStart="@(new Icons.Regular.Size20.Search())"
                                  Appearance="Appearance.Accent">
                        Suchen
                    </FluentButton>
                </FluentStack>

            </EditForm>
        </FluentCard>
    </FluentGridItem>
</FluentGrid>
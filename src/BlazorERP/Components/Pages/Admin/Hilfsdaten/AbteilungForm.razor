@page "/Admin/Abteilungen/Edit"
@using BlazorERP.Core.Validators.Admin.Hilfsdaten
@using Microsoft.AspNetCore.Identity
@inject AuthService authService
@inherits EditPageBase<int?, Abteilung, AbteilungService>
@inject IMessageService messageService
@inject IDialogService DialogService
<PageTitle>@FinalBreadcrumbItemName</PageTitle>


<FluentBreadcrumb>
    <FluentBreadcrumbItem Href="/">Start</FluentBreadcrumbItem>
    <FluentBreadcrumbItem>Administration</FluentBreadcrumbItem>
    <FluentBreadcrumbItem Href="/Admin/Abteilungen">Abteilungen</FluentBreadcrumbItem>
    <FluentBreadcrumbItem>@FinalBreadcrumbItemName</FluentBreadcrumbItem>
</FluentBreadcrumb>
@if (Input is null)
{
    return;
}

<FluentGrid>
    <FluentGridItem xs="12">
        <FluentStack HorizontalAlignment="HorizontalAlignment.End">
            <FluentAnchor Href="/Admin/Abteilungen"
                          IconStart="@(new Icons.Regular.Size20.ArrowReply())">
                Zurück
            </FluentAnchor>

            @if (Modus is EditMode.Edit)
            {
                <FluentButton id="btnOpen1" Appearance="Appearance.Accent" @onclick="@(() => _showOptionsMenu = !_showOptionsMenu)">
                    Optionen
                </FluentButton>

                <FluentMenu Anchor="btnOpen1" @bind-Open="_showOptionsMenu" VerticalThreshold="170">
                    <FluentMenuItem OnClick="ShowDeleteModalAsync">Abteilung löschen</FluentMenuItem>
                </FluentMenu>
            }

            <FluentButton IconStart="@(new Icons.Regular.Size20.Save())"
                          Appearance="Appearance.Accent"
                          OnClick="SaveAsync">

                Speichern
            </FluentButton>
        </FluentStack>
    </FluentGridItem>
    <FluentGridItem md="4" HiddenWhen="GridItemHidden.MdAndDown"></FluentGridItem>
    <FluentGridItem xs="12" md="4">

        <FluentCard>
            <EditForm Model="Input" @ref="_form">
                <FluentValidationValidator Validator="_validator" />
                <FluentGrid Spacing="1">
                    @if(Modus is EditMode.Edit)
                    {
                        <FluentGridItem xs="12">
                            <FluentNumberField @bind-Value="Input.AbteilungId" Label="AbteilungId" Disabled />
                        </FluentGridItem>
                    }
                    <FluentGridItem xs="12">
                        <FluentTextField @bind-Value="Input.Name" Label="Name" />
                        <FluentValidationMessage For="() => Input.Name" />
                    </FluentGridItem>

                    <FluentGridItem xs="12">
                        <FluentTextField @bind-Value="Input.ActiveDirectoryGroupCN" Label="Active Directory Gruppen-CN" />
                        <FluentValidationMessage For="() => Input.ActiveDirectoryGroupCN" />
                    </FluentGridItem>
                </FluentGrid>
            </EditForm>
        </FluentCard>
    </FluentGridItem>
    <FluentGridItem md="4" HiddenWhen="GridItemHidden.MdAndDown"></FluentGridItem>
</FluentGrid>

@code {


    private bool _showOptionsMenu;
    private AbteilungValidator _validator = new();


    protected override string GetEntityRedirectUrl() => $"/Admin/Abteilungen/Edit?abteilungId={Input!.AbteilungId}";


    [Parameter, SupplyParameterFromQuery(Name = "abteilungId")]
    public override int? Identifier { get; set; }

    
    private async Task ShowDeleteModalAsync()
    {

        var dialog = await DialogService.ShowDialogAsync<DeleteDialog<Abteilung, AbteilungService>>(Input!, new CustomDialogParameters()
            {
                Title = $"Abteilung löschen",
                PreventDismissOnOverlayClick = true,
                PreventScroll = true,
                Text = $"Möchten Sie die Abteilung \"{Input!.GetName()}\" wirklich löschen?"
            });

        var result = await dialog.Result;

        if (!result.Cancelled)
        {
            messageService.ShowMessageBar(options =>
            {
                options.Title = "Abteilung wurde erfolgreich gelöscht!";
                options.Intent = MessageIntent.Success;
                options.Section = Constants.MESSAGEBAR_TOP_SECTION;
                options.Timeout = 4000;
            });
            
            NavigationManager.NavigateTo("/Admin/Abteilungen");
        }
    }

}
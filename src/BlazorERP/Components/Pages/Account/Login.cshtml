@page
@model BlazorERP.Components.Pages.Account.LoginModel
@{
    Layout = null;
}
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
<!DOCTYPE html>
<html lang="de">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - BlazorERP</title>
    <link rel="stylesheet" href="/assets/css/auth.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-rbsA2VBKQhggwzxH7pPCaAqO46MgnOM80zW1RWuH61DGLwZJEdK2Kadq2F9CUG65" crossorigin="anonymous">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link rel="shortcut icon" href="favicon.ico" type="image/x-icon">


    

    <link href="/site.webmanifest" rel="manifest" />
</head>

<body>
    <div id="auth">

        <div class="row h-100">
            <div class="col-lg-6 offset-lg-3 col-12">
                <div id="auth-left">                 
                    <h2 class="auth-title">Login</h2>
                    <p class="auth-subtitle mb-5">BlazorERP</p>

                    <form method="post">
                        <div asp-validation-summary="All" class="text-danger"></div>
                        <div class="form-group position-relative has-icon-left mb-4">
                            <input asp-for="Input.Username" type="text" class="form-control form-control-xl" placeholder="Username">
                            <div class="form-control-icon">
                                <i class="bi bi-person-fill"></i>
                            </div>
                            <span asp-validation-for="Input.Username" class="text-danger"></span>
                        </div>
                        <div class="form-group position-relative has-icon-left mb-4">
                            <input asp-for="Input.Password" type="password" class="form-control form-control-xl" placeholder="Passwort">
                            <div class="form-control-icon">
                                <i class="bi bi-lock-fill"></i>
                            </div>
                            <span asp-validation-for="Input.Password" class="text-danger"></span>
                        </div>
                        <div class="form-check form-check-lg d-flex align-items-end">
                            <input asp-for="Input.RememberMe" class="form-check-input me-2" id="flexCheckDefault">
                            <label asp-for="Input.RememberMe" class="form-check-label text-gray-600" for="flexCheckDefault">
                                @Html.DisplayNameFor(m => m.Input.RememberMe)
                            </label>
                        </div>
                        <button class="btn btn-primary btn-block btn-lg shadow-lg mt-5 mb-3">Login</button>
                    </form>
                </div>
            </div>
        </div>

    </div>
</body>

</html>

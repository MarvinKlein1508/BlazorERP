@page "/Stammdaten/Kunden/Edit"
@using BlazorERP.Core.Validators.Admin.Hilfsdaten
@using Microsoft.AspNetCore.Identity
@inherits EditPageBase<string?, Kunde, KundeService>

<PageTitle>@FinalBreadcrumbItemName</PageTitle>

<FluentBreadcrumb>
    <FluentBreadcrumbItem Href="/">Start</FluentBreadcrumbItem>
    <FluentBreadcrumbItem>Administration</FluentBreadcrumbItem>
    <FluentBreadcrumbItem Href="/Stammdaten/Kunden">Kunden</FluentBreadcrumbItem>
    <FluentBreadcrumbItem>@FinalBreadcrumbItemName</FluentBreadcrumbItem>
</FluentBreadcrumb>
@if (Input is null)
{
    return;
}
<FluentStack HorizontalAlignment="HorizontalAlignment.End">
    <FluentAnchor Href="/Stammdaten/Kunden"
                  IconStart="@(new Icons.Regular.Size20.ArrowReply())">
        Zurück
    </FluentAnchor>

    @if (Modus is EditMode.Edit)
    {
        <FluentButton id="btnOpen1" Appearance="Appearance.Accent" @onclick="@(() => _showOptionsMenu = !_showOptionsMenu)">
            Optionen
        </FluentButton>

        <FluentMenu Anchor="btnOpen1" @bind-Open="_showOptionsMenu" VerticalThreshold="170">
            <FluentMenuItem OnClick="ShowDeleteModalAsync">Kunde löschen</FluentMenuItem>
        </FluentMenu>
    }

    <FluentButton IconStart="@(new Icons.Regular.Size20.Save())"
                  Appearance="Appearance.Accent"
                  OnClick="SaveAsync">

        Speichern
    </FluentButton>
</FluentStack>

<EditForm Model="Input" @ref="_form">
    <FluentValidationValidator Validator="_validator" />
    <FluentTabs>
        <FluentTab Label="Allgemein">
            <div class="row">
                <div class="col-md-9">
                    <div class="row">
                        <div class="col-md-6">
                            <FluentTextField @bind-Value="Input.Firma" Label="Firma" />
                            <FluentValidationMessage For="() => Input.Firma" />

                            <FluentTextField @bind-Value="Input.Name1" Label="Name1" />
                            <FluentValidationMessage For="() => Input.Name1" />

                            <FluentTextField @bind-Value="Input.Name2" Label="Name2" />
                            <FluentValidationMessage For="() => Input.Name2" />

                            <FluentTextField @bind-Value="Input.Strasse" Label="Straße" />
                            <FluentValidationMessage For="() => Input.Strasse" />

                            <div class="row">
                                <div class="col-md-4">
                                    <FluentSelect TOption="Land"
                                                  Label="Land"
                                                  Width="100%;"
                                                  Items="@([Storage.EmptyLand,..Storage.Get<Land>()])"
                                                  OptionValue="@(p => p.LandId.ToString())"
                                                  OptionText="@(p => p.Name)"
                                                  OptionSelected="(option) => Input.LandId is null && option is null || Input.LandId == option.LandId"
                                                  SelectedOptionChanged="(option) => Input.LandId = option.LandId > 0 ? option.LandId : null" />

                                    <p>Land: @Input.LandId</p>

                                </div>
                                <div class="col-md-4">
                                    <FluentTextField @bind-Value="Input.Postleitzahl" Label="Postleitzahl" />
                                    <FluentValidationMessage For="() => Input.Postleitzahl" />
                                </div>
                                <div class="col-md-4">
                                    <FluentTextField @bind-Value="Input.Ort" Label="Postleitzahl" />
                                    <FluentValidationMessage For="() => Input.Ort" />
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">

                            <div class="row">
                                <div class="col-6">
                                    <FluentSelect TOption="Sprache"
                                                  Label="Sprache"
                                                  Width="100%;"
                                                  Items="@([Storage.EmptySprache,..Storage.Get<Sprache>()])"
                                                  OptionValue="@(p => p.SprachId.ToString())"
                                                  OptionText="@(p => p.Name)"
                                                  OptionSelected="(option) => Input.AnredeId == option.SprachId"
                                                  SelectedOptionChanged="(option) => Input.LandId = option.SprachId > 0 ? option.SprachId : null" />
                                    <FluentValidationMessage For="() => Input.SprachId" />
                                </div>

                                <div class="col-6">
                                    <FluentSelect TOption="Anrede"
                                                  Label="Anrede"
                                                  Width="100%;"
                                                  Items="@([Storage.EmptyAnrede,..Storage.Get<Anrede>()])"
                                                  OptionValue="@(p => p.AnredeId.ToString())"
                                                  OptionText="@(p => p.Name)"
                                                  OptionSelected="(option) => Input.AnredeId == option.AnredeId"
                                                  SelectedOptionChanged="(option) => Input.LandId = option.AnredeId > 0 ? option.AnredeId : null" />
                                    <FluentValidationMessage For="() => Input.AnredeId" />
                                </div>
                                <div class="col-md-6">
                                    <FluentTextField @bind-Value="Input.Telefonnummer" Label="Telefonnummer" />
                                    <FluentValidationMessage For="() => Input.Telefonnummer" />
                                </div>
                                <div class="col-md-6">
                                    <FluentTextField @bind-Value="Input.Mobilnummer" Label="Mobilnummer" />
                                    <FluentValidationMessage For="() => Input.Mobilnummer" />
                                </div>

                                <div class="col-md-6">
                                    <FluentTextField @bind-Value="Input.Email" Label="E-Mail" />
                                    <FluentValidationMessage For="() => Input.Email" />
                                </div>
                                <div class="col-md-6">
                                    <div class="input-group">
                                        <FluentTextField @bind-Value="Input.Website" Immediate="true" Label="Website" />
                                        <FluentAnchor Appearance="Appearance.Accent" Href="@Input.Website" Target="_blank" IconStart="@(new Icons.Regular.Size20.Open().WithColor(Color.Fill))" />
                                    </div>
                                    <FluentValidationMessage For="() => Input.Website" />
                                </div>
                                <div class="col-12">
                                    <FluentTextArea @bind-Value="Input.Notiz" Label="Notiz" Class="w-100" Rows="6" />
                                    <FluentValidationMessage For="() => Input.Notiz" />
                                </div>
                            </div>

                        </div>
                    </div>
                </div>
                <div class="col-md-3 ">
                    <div class="row">
                        @if (Modus is EditMode.Edit)
                        {
                            <div class="col-12">
                                <FluentTextField Value="@Input.Anlagedatum?.ToShortDateString()" Appearance="FluentInputAppearance.Filled" Label="Anlagedatum" ReadOnly />
                            </div>
                            <div class="col-12">
                                <div class="d-flex flex-column gap-2 mt-2">
                                    <FluentSwitch @bind-Value="@Input.IstGesperrt" Label="Gesperrt" />
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </FluentTab>
        <FluentTab Label="Finanzdaten">
            <Content>
                <div class="row">
                    <div class="col-md-9">
                        <div class="row">
                            <div class="col-md-6">
                                <FluentSelect TOption="Lieferbedingung"
                                              Label="Lieferbedingung"
                                              Width="100%;"
                                              Items="@([Storage.EmptyLieferbedingung,..Storage.Get<Lieferbedingung>()])"
                                              OptionValue="@(p => p.LieferbedingungId.ToString())"
                                              OptionText="@(p => p.Name)"
                                              OptionSelected="(option) => Input.LandId == option.LieferbedingungId"
                                              SelectedOptionChanged="(option) => Input.LandId = option.LieferbedingungId > 0 ? option.LieferbedingungId : null" />
                                <FluentValidationMessage For="() => Input.LieferbedingungId" />

                            </div>
                            <div class="col-md-6">
                                <FluentSelect TOption="Zahlungsbedingung"
                                              Label="Zahlungsbedingung"
                                              Width="100%;"
                                              Items="@([Storage.EmptyZahlungsbedingung,..Storage.Get<Zahlungsbedingung>()])"
                                              OptionValue="@(p => p.ZahlungsbedingungId.ToString())"
                                              OptionText="@(p => p.Name)"
                                              OptionSelected="(option) => Input.LandId == option.ZahlungsbedingungId"
                                              SelectedOptionChanged="(option) => Input.LandId = option.ZahlungsbedingungId > 0 ? option.ZahlungsbedingungId : null" />
                                <FluentValidationMessage For="() => Input.ZahlungsbedingungId" />
                            </div>
                            <div class="col-md-6">
                                <FluentNumberField @bind-Value="Input.Kreditlimit" Label="Kreditlimit" />
                                <FluentValidationMessage For="() => Input.Kreditlimit" />
                            </div>

                            <div class="col-md-6">
                                <div class="input-group">
                                    <FluentTextField @bind-Value="Input.UmsatzsteuerIdentifikationsnummer" Label="Ust. ID-Nummer" />
                                    <FluentButton Appearance="Appearance.Accent" IconStart="@(new Icons.Regular.Size20.BuildingBank().WithColor(Color.Fill))" />
                                </div>
                                <FluentValidationMessage For="() => Input.UmsatzsteuerIdentifikationsnummer" />
                            </div>

                            <div class="col-md-6">
                                <div class="row">
                                    <div class="col-md-6">
                                        <FluentTextField @bind-Value="Input.IBAN" Label="IBAN" />
                                        <FluentValidationMessage For="() => Input.IBAN" />
                                    </div>
                                    <div class="col-md-6">
                                        <FluentTextField @bind-Value="Input.BIC" Label="BIC" />
                                        <FluentValidationMessage For="() => Input.BIC" />
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3 ">
                        <div class="row">
                        </div>
                    </div>
                </div>
            </Content>
        </FluentTab>
        <FluentTab Label="Historie">
            <Content>

            </Content>
        </FluentTab>
    </FluentTabs>
</EditForm>
@code {

    private bool _showOptionsMenu;
    private ZahlungsbedingungValidator _validator = new();

    protected override string GetListUrl() => "/Stammdaten/Kunden";
    protected override string GetEntityRedirectUrl() => $"/Stammdaten/Kunden/Edit?kundennummer={Input!.Kundennummer}";



    [Parameter, SupplyParameterFromQuery(Name = "kundennummer")]
    public override string? Identifier { get; set; }



    protected override Task BeforeSaveAsync(IDbController dbController)
    {
        Input.LetzterBearbeiter = User.UserId;
        Input.ZuletztGeaendert = DateTime.Now;

        return Task.CompletedTask;
    }

}
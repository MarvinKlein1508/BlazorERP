@inherits LayoutComponentBase

<AuthorizeView>
    <NotAuthorized>
        <RedirectToLogin @rendermode="InteractiveServer" />
    </NotAuthorized>
    <Authorized>
        <FluentLayout>
            <FluentHeader>
                BlazorERP
            </FluentHeader>
            <FluentStack Class="main" Orientation="Orientation.Horizontal" Width="100%">
                <NavMenu @rendermode="InteractiveServer" />
                <FluentBodyContent Class="body-content">
                    <div class="content">
                        <FluentMessageBarProvider Section="MESSAGES_TOP" />
                        @Body
                    </div>
                </FluentBodyContent>
            </FluentStack>
            <FluentFooter>
                <div class="link1">
                    <a href="https://www.fluentui-blazor.net" target="_blank">Documentation and demos</a>
                </div>
                <div class="link2">
                    <a href="https://learn.microsoft.com/en-us/aspnet/core/blazor" target="_blank">About Blazor</a>
                </div>
            </FluentFooter>

        </FluentLayout>

        <FluentToastProvider @rendermode="InteractiveServer" RemoveToastsOnNavigation="false" Position="ToastPosition.TopCenter" />
    </Authorized>
</AuthorizeView>



<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>